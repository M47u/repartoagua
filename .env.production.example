# ==================================
# CONFIGURACIÓN DE PRODUCCIÓN - HOSTINGER
# ==================================
# Este archivo es una plantilla para configurar tu aplicación Laravel en Hostinger.
# INSTRUCCIONES:
# 1. Copia este archivo y renómbralo a ".env" en tu servidor
# 2. Rellena todos los valores según tu configuración de Hostinger
# 3. Genera una APP_KEY nueva con: php artisan key:generate
# 4. Revisa especialmente DB_*, MAIL_* y MAPBOX_ACCESS_TOKEN
# 5. NUNCA subas este archivo con datos reales a Git
# ==================================

# ==================================
# APLICACIÓN
# ==================================
APP_NAME="Reparto Agua"
APP_ENV=production
APP_KEY=base64:GENERA_TU_KEY_CON_php_artisan_key:generate
APP_DEBUG=false
APP_TIMEZONE=America/Argentina/Buenos_Aires
APP_URL=https://tu-dominio.com

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_AR

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ==================================
# BASE DE DATOS
# ==================================
# IMPORTANTE: Obtén estos datos desde el panel de Hostinger
# En hPanel > Bases de datos > MySQL > Ver detalles de la base de datos

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=nombre_base_datos_hostinger
DB_USERNAME=usuario_base_datos_hostinger
DB_PASSWORD=contraseña_base_datos_hostinger

# ==================================
# SESIONES Y CACHÉ
# ==================================
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=reparto_
MEMCACHED_HOST=127.0.0.1

# ==================================
# REDIS (Opcional - Si está disponible en tu plan de Hostinger)
# ==================================
# Redis mejora el rendimiento del caché y sesiones
# Si tu plan de Hostinger incluye Redis, puedes activarlo:
# CACHE_STORE=redis
# SESSION_DRIVER=redis
# QUEUE_CONNECTION=redis
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ==================================
# OPTIMIZACIONES DE PHP
# ==================================
# Hostinger usa varios workers PHP. Ajusta según tu plan:
PHP_CLI_SERVER_WORKERS=4

# ==================================
# CORREO ELECTRÓNICO
# ==================================
# Si usas el SMTP de Hostinger:
MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=tu-email@tu-dominio.com
MAIL_PASSWORD=tu-password-email
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=noreply@tu-dominio.com
MAIL_FROM_NAME="${APP_NAME}"

# Si no usas email, déjalo en log:
# MAIL_MAILER=log

# ==================================
# AWS (si usas S3 para archivos)
# ==================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ==================================
# VITE (importante para assets)
# ==================================
VITE_APP_NAME="${APP_NAME}"

# ==================================
# MAPBOX (Mapas y Rutas Optimizadas)
# ==================================
# Obtén tu token gratis en: https://account.mapbox.com/
# Necesario para funcionalidad de mapas y optimización de rutas
MAPBOX_ACCESS_TOKEN=tu_mapbox_token_aqui

# ==================================
# NOTAS IMPORTANTES PARA HOSTINGER
# ==================================
# 
# DESPUÉS DE SUBIR LA APLICACIÓN:
# 1. Ejecuta: php artisan migrate --force (para crear las tablas)
# 2. Ejecuta: php artisan storage:link (para enlazar almacenamiento público)
# 3. Ejecuta: php artisan config:cache (optimiza configuraciones)
# 4. Ejecuta: php artisan route:cache (optimiza rutas)
# 5. Ejecuta: php artisan view:cache (optimiza vistas)
# 6. Verifica permisos: chmod -R 775 storage bootstrap/cache
# 7. Verifica que el DocumentRoot apunte a /public_html/public
#
# SEGURIDAD:
# - Nunca pongas APP_DEBUG=true en producción
# - Mantén APP_KEY segura y única
# - Usa contraseñas fuertes en DB_PASSWORD y MAIL_PASSWORD
# - Revisa logs regularmente en: storage/logs/
#
# SOPORTE:
# - Documentación Laravel: https://laravel.com/docs
# - Soporte Hostinger: https://www.hostinger.com/tutorials
# - hPanel: Accede desde tu cuenta de Hostinger
